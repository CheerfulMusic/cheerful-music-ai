# Configure these in Vercel Project Settings > Environment Variables.
# Never put real values in this file or commit them to GitHub.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
CHEERFUL_GPT_SESSION_SECRET=
CHEERFUL_GPT_ACCESS_KEYS=

# Optional: enables cross-device history and queryable audit logs.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
