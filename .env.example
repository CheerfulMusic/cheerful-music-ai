# Configure these in Vercel Project Settings > Environment Variables.
# Never put real values in this file or commit them to GitHub.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
CHEERFUL_GPT_SESSION_SECRET=
# JSON key = login password; each value should include id, email, name, and role.
CHEERFUL_GPT_ACCESS_KEYS=

# Supabase: database, Auth, Storage, RLS, and cross-device data.
# Prefer the new publishable/secret keys shown in Supabase Project Settings > API Keys.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Legacy aliases remain supported during Supabase's key transition.
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
